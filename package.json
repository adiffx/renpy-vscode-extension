{
  "name": "renpy-language-support",
  "displayName": "Ren'Py Magic",
  "description": "Complete language support for Ren'Py visual novel engine - syntax highlighting, completions, hover docs, go-to-definition, and diagnostics",
  "version": "1.0.7",
  "publisher": "adiffx",
  "author": {
    "name": "adiffx"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adiffx/renpy-magic"
  },
  "bugs": {
    "url": "https://github.com/adiffx/renpy-magic/issues"
  },
  "homepage": "https://adiffx.com/renpy-magic/",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#2d2d2d",
    "theme": "dark"
  },
  "keywords": [
    "renpy",
    "ren'py",
    "visual novel",
    "game development",
    "atl"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "activationEvents": [
    "onLanguage:renpy"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "renpy",
        "aliases": [
          "Ren'Py",
          "renpy"
        ],
        "extensions": [
          ".rpy",
          ".rpym"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "renpy",
        "scopeName": "source.renpy",
        "path": "./syntaxes/renpy.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Ren'Py Magic",
      "properties": {
        "renpyMagic.diagnostics.warnUndefinedImages": {
          "type": "boolean",
          "default": false,
          "description": "Warn when show/scene references an image not defined in code. Disabled by default because images are often defined as files rather than in code."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && cp src/server/renpy-api.json out/server/",
    "watch": "tsc -watch -p ./",
    "test": "jest",
    "fetch-api": "npx ts-node scripts/fetch-renpy-docs.ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.7.1",
    "jest": "^30.3.0",
    "marked": "^17.0.5",
    "mustache": "^4.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  }
}
